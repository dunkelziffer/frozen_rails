#!/bin/bash

# generated by frozen:ssg
# Usage: ./create-index-symlinks /path/to/website
set -e

if [ -z "$1" ]; then
    echo "Usage: $0 <path_to_website_directory>"
    exit 1
fi

ROOT_DIR="$1"
ROOT_DIR=$(realpath "$ROOT_DIR")

process_dir() {
    local dir="$1"

    # Normalize path to remove duplicate slashes
    dir=$(realpath -m "$dir")

    # Skip hidden directories
    if [[ "$(basename "$dir")" == .* ]]; then
        return
    fi

    # Only create index.html if it doesn't exist
    if [ ! -f "$dir/index.html" ]; then
        dir_name=$(basename "$dir")
        parent_dir=$(dirname "$dir")
        target_file="$parent_dir/$dir_name.html"

        # Only create symlink if target exists
        if [ -f "$target_file" ]; then
            # Compute relative path from current dir to target
            rel_path=$(realpath --relative-to="$dir" "$target_file")
            echo "Creating symlink: $dir/index.html -> $rel_path"
            ln -s "$rel_path" "$dir/index.html"
        else
            echo "Skipping $dir: target $target_file does not exist"
        fi
    fi

    # Recurse into subdirectories
    for subdir in "$dir"/*/; do
        [ -d "$subdir" ] || continue
        process_dir "$subdir"
    done
}
